rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    /* ================= Helpers ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn()
        && firestore.exists(
          /databases/(default)/documents/users/$(request.auth.uid)
        );
    }

    function userDoc() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      );
    }

    function userHasRole(roleName) {
      return hasUserDoc()
        && (
          (
            userDoc().data.keys().hasAny(["role"])
            && userDoc().data.role == roleName
          )
          ||
          (
            userDoc().data.keys().hasAny(["primaryRole"])
            && userDoc().data.primaryRole == roleName
          )
          ||
          (
            userDoc().data.keys().hasAny(["roles"])
            && userDoc().data.roles is list
            && roleName in userDoc().data.roles
          )
        );
    }

    function isRoot() {
      return userHasRole("root");
    }

    function userInmobiliarias() {
      return hasUserDoc()
        && userDoc().data.keys().hasAny(["inmobiliarias"])
        && userDoc().data.inmobiliarias is list
        ? userDoc().data.inmobiliarias
        : [];
    }

    function belongsToUserInmobiliaria(inmobiliariaId) {
      return isSignedIn()
        && inmobiliariaId in userInmobiliarias();
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isValidImageSize() {
      return request.resource != null
        && request.resource.size <= 10 * 1024 * 1024;
    }
    
    function isValidParticularRequestImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size <= 10 * 1024 * 1024;
    }

    function isValidVerificationFile() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
          '^(application/pdf|image/jpeg|image/png)$'
        );
    }

    /* ================= Inmobiliarias - documentación privada ================= */

    match /inmobiliarias/{inmobiliariaId}/verificacion/{userId}/{fileName} {

      allow read: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);

      allow create, update: if
        isSignedIn()
        && request.auth.uid == userId
        && belongsToUserInmobiliaria(inmobiliariaId)
        && isValidVerificationFile();

      allow delete: if
        isRoot()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && belongsToUserInmobiliaria(inmobiliariaId)
        );
    }

    /* ================= Inmobiliarias - branding público ================= */

    match /inmobiliarias/{inmobiliariaId}/branding/{allPaths=**} {

      allow read: if true;

      allow create, update: if
        isSignedIn()
        && belongsToUserInmobiliaria(inmobiliariaId)
        && isImage()
        && isValidImageSize();

      allow delete: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);
    }

    match /inmobiliarias/{inmobiliariaId}/logo/{allPaths=**} {

      allow read: if true;

      allow create, update: if
        isSignedIn()
        && belongsToUserInmobiliaria(inmobiliariaId)
        && isImage()
        && isValidImageSize();

      allow delete: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);
    }

    match /inmobiliarias/{inmobiliariaId}/backgrounds/{allPaths=**} {

      allow read: if true;

      allow create, update: if
        isSignedIn()
        && belongsToUserInmobiliaria(inmobiliariaId)
        && isImage()
        && isValidImageSize();

      allow delete: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);
    }

    match /inmobiliarias/{inmobiliariaId}/{fileName} {

      allow read: if true;

      allow create, update: if
        isSignedIn()
        && belongsToUserInmobiliaria(inmobiliariaId)
        && isImage()
        && isValidImageSize();

      allow delete: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);
    }

    /* ================= Inmuebles ================= */

    match /inmuebles/{inmobiliariaId}/{inmuebleId}/{fileName} {

      allow read: if true;

      allow create, update: if
  isSignedIn()
  && (
    isRoot()
    || belongsToUserInmobiliaria(inmobiliariaId)
  )
  && isImage()
  && isValidImageSize();

      allow delete: if
        isRoot()
        || belongsToUserInmobiliaria(inmobiliariaId);
    }

    /* ================= Solicitudes particulares - imágenes privadas =================
       Ruta:
       /particular_publication_requests/{requestId}/{userId}/{fileName}
    */

    match /particular_publication_requests/{requestId}/{userId}/{fileName} {
    
      allow get: if isSignedIn();

      allow list: if false;

      allow create: if
        isSignedIn()
        && request.auth.uid == userId
        && isValidParticularRequestImage();

     allow update: if false;

     allow delete: if
       isRoot()
       || (
         isSignedIn()
         && request.auth.uid == userId
       );
    }

    /* ================= Fallback ================= */

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}