rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================
       Helpers generales
       ============================ */

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isRoot() {
      return userRole() == "root";
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function adminHasInmobiliaria(inmoId) {
      return isAdmin()
        && inmoId in userDoc().data.inmobiliarias;
    }

    function belongsToUserInmobiliaria(inmoId) {
      return isSignedIn()
        && inmoId in userDoc().data.inmobiliarias;
    }

    function isOwner(resource) {
      return isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    /* ============================
       Inmuebles – helpers
       ============================ */

    function isPublicInmueble(resource) {
      return resource != null
        && resource.data.estado == "activo"
        && resource.data.deleted == false
        && resource.data.publicarEnPortal == true;
    }

    function isSharedWithUser(resource, inmoId) {
      return isSignedIn()
        && resource.data.sharedWith != null
        && inmoId in resource.data.sharedWith;
    }

    function canSharedRead(resource, inmoId) {
      return isSharedWithUser(resource, inmoId)
        && resource.data.sharedWith[inmoId].canRead == true;
    }

    function canSharedUpdate(resource, inmoId) {
      return isSharedWithUser(resource, inmoId)
        && resource.data.sharedWith[inmoId].canUpdate == true;
    }

    function sharedCanUpdateOnlyAllowedFields(resource) {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "titulo",
          "descripcion",
          "precio",
          "moneda",
          "expensas",
          "estado",
          "destacado",
          "orden",
          "images",
          "updatedAt"
        ]);
    }

    /* ============================
       USERS
       ============================ */

    match /users/{userId} {

      allow read: if
        isSignedIn()
        && request.auth.uid == userId;

      allow create: if
        isSignedIn()
        && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/users/$(userId));

      allow update, delete: if isRoot();
    }

    /* ============================
       INMOBILIARIAS
       ============================ */

    match /inmobiliarias/{inmoId} {

      allow read: if
        isRoot()
        || adminHasInmobiliaria(inmoId);

      allow write: if isRoot();

      /* ============================
         SUBCOLECCIÓN INMUEBLES
         ============================ */

      match /inmuebles/{inmuebleId} {

        /* =========
           READ
           ========= */
        allow read: if
          isRoot()
          || adminHasInmobiliaria(inmoId)
          || isOwner(resource)
          || canSharedRead(resource, inmoId)
          || isPublicInmueble(resource);

        /* =========
           CREATE
           ========= */
        allow create: if
          isSignedIn()
          && (
            isRoot()
            || (
              isAdmin()
              && belongsToUserInmobiliaria(inmoId)
              && request.resource.data.ownerId == request.auth.uid
              && request.resource.data.ownerInmobiliariaId == inmoId
            )
          );

        /* =========
           UPDATE
           ========= */
        allow update: if
          isSignedIn()
          && (
            isRoot()
            || adminHasInmobiliaria(inmoId)
            || isOwner(resource)
            || (
              canSharedUpdate(resource, inmoId)
              && sharedCanUpdateOnlyAllowedFields(resource)
            )
          );

        /* =========
           DELETE
           ========= */
        allow delete: if
          isRoot()
          || adminHasInmobiliaria(inmoId);
      }
    }

    /* ============================
       COLLECTION GROUP: INMUEBLES PÚBLICOS
       ============================

       Necesario para consultas:
       collectionGroup(db, "inmuebles")

       Permite leer únicamente inmuebles publicados en portal.
    */

    match /{path=**}/inmuebles/{inmuebleId} {
      allow read: if isPublicInmueble(resource);
      allow create, update, delete: if false;
    }
/* ============================
   CONSULTAS DE INMUEBLES
   ============================ */

match /inmueble_consultas/{consultaId} {

  // Cualquier visitante puede crear una consulta desde la ficha pública.
  allow create: if
    request.resource.data.inmuebleId is string
    && request.resource.data.inmobiliariaId is string
    && request.resource.data.nombre is string
    && request.resource.data.nombre.size() >= 2
    && (
      (
        request.resource.data.email is string
        && request.resource.data.email.size() >= 5
      )
      ||
      (
        request.resource.data.telefono is string
        && request.resource.data.telefono.size() >= 6
      )
    )
    && request.resource.data.estado == "nueva"
    && request.resource.data.leida == false
    && request.resource.data.archivada == false;

  // Puede leer consultas el root o el admin de la inmobiliaria correspondiente.
  allow read: if
    isRoot()
    || adminHasInmobiliaria(resource.data.inmobiliariaId);

  // El admin puede gestionar solo estado interno de la consulta.
  allow update: if
    isSignedIn()
    && (
      isRoot()
      || adminHasInmobiliaria(resource.data.inmobiliariaId)
    )
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "estado",
        "leida",
        "archivada",
        "updatedAt"
      ]);

  // Borrado físico solo root. Para admins usamos archivado.
  allow delete: if isRoot();
}
    /* ============================
       TESTIMONIALS
       ============================ */

    match /testimonials/{testimonialId} {

      allow read: if true;

      allow create: if isSignedIn();

      allow update, delete: if isAdmin() || isRoot();
    }

    /* ============================
       CIERRE TOTAL
       ============================ */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}