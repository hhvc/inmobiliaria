rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================
       Helpers generales
       ============================ */

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userHasRole(roleName) {
      return isSignedIn()
        && (
          (
            userDoc().data.keys().hasAny(["role"])
            && userDoc().data.role == roleName
          )
          ||
          (
            userDoc().data.keys().hasAny(["primaryRole"])
            && userDoc().data.primaryRole == roleName
          )
          ||
          (
            userDoc().data.keys().hasAny(["roles"])
            && userDoc().data.roles is list
            && roleName in userDoc().data.roles
          )
        );
    }

    function inmobiliariaPath(inmoId) {
  return /databases/$(database)/documents/inmobiliarias/$(inmoId);
}

function isSelfCreatedInmobiliaria(inmoId) {
  return isSignedIn()
    && exists(inmobiliariaPath(inmoId))
    && get(inmobiliariaPath(inmoId)).data.createdBy == request.auth.uid
    && get(inmobiliariaPath(inmoId)).data.admins is list
    && request.auth.uid in get(inmobiliariaPath(inmoId)).data.admins;
}

    function isRoot() {
      return userHasRole("root");
    }

    function isAdmin() {
      return userHasRole("admin");
    }

    function userInmobiliarias() {
      return isSignedIn()
        && userDoc().data.keys().hasAny(["inmobiliarias"])
        && userDoc().data.inmobiliarias is list
        ? userDoc().data.inmobiliarias
        : [];
    }

    function isInmobiliariaUser() {
      return isSignedIn()
        && userInmobiliarias().size() > 0;
    }

    function adminHasInmobiliaria(inmoId) {
      return isAdmin()
        && inmoId in userInmobiliarias();
    }

    function belongsToUserInmobiliaria(inmoId) {
      return isSignedIn()
        && inmoId in userInmobiliarias();
    }

    function isOwner(resource) {
      return isSignedIn()
        && resource != null
        && resource.data.ownerId == request.auth.uid;
    }

    /* ============================
       Inmuebles – helpers
       ============================ */

    function isPublicInmueble(resource) {
      return resource != null
        && resource.data.estado == "activo"
        && resource.data.deleted == false
        && resource.data.publicarEnPortal == true;
    }

    function isPublicInmobiliaria(resource) {
      return resource != null
        && resource.data.activa == true;
    }

    function inmuebleParentPath(inmoId, inmuebleId) {
      return /databases/$(database)/documents/inmobiliarias/$(inmoId)/inmuebles/$(inmuebleId);
    }

    function hasParentInmueble(inmoId, inmuebleId) {
      return exists(inmuebleParentPath(inmoId, inmuebleId));
    }

    function parentInmueble(inmoId, inmuebleId) {
      return get(inmuebleParentPath(inmoId, inmuebleId));
    }

    function isSharedNetworkInmueble(resource) {
      return resource != null
        && resource.data.deleted == false
        && resource.data.estado == "activo"
        && resource.data.keys().hasAny(["sharing"])
        && resource.data.sharing.enabled == true
        && resource.data.sharing.mode == "all_colleagues";
    }

    function canReadNetworkInmueble(resource) {
      return isInmobiliariaUser()
        && isSharedNetworkInmueble(resource);
    }

    function isSharedWithUser(resource, inmoId) {
      return isSignedIn()
        && resource.data.sharedWith != null
        && inmoId in resource.data.sharedWith;
    }

    function canSharedRead(resource, inmoId) {
      return isSharedWithUser(resource, inmoId)
        && resource.data.sharedWith[inmoId].canRead == true;
    }

    function canSharedUpdate(resource, inmoId) {
      return isSharedWithUser(resource, inmoId)
        && resource.data.sharedWith[inmoId].canUpdate == true;
    }

    function sharedCanUpdateOnlyAllowedFields(resource) {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "titulo",
          "descripcion",
          "precio",
          "moneda",
          "expensas",
          "estado",
          "destacado",
          "orden",
          "images",
          "updatedAt"
        ]);
    }

    function inmueblePublicDataHasNoProtectedFields(data) {
      return !data.keys().hasAny([
        "networkData",
        "privateData",
        "exactAddress",
        "commissionShare",
        "internalPrice",
        "documentationStatus",
        "visitInstructions",
        "notesForColleagues",
        "ownerName",
        "ownerPhone"
      ]);
    }

    function canReadInmueblePrivateData(inmoId, inmuebleId) {
      return isRoot()
        || adminHasInmobiliaria(inmoId)
        || (
          hasParentInmueble(inmoId, inmuebleId)
          && (
            isOwner(parentInmueble(inmoId, inmuebleId))
            || canReadNetworkInmueble(parentInmueble(inmoId, inmuebleId))
          )
        );
    }

    function canManageInmueblePrivateData(inmoId, inmuebleId) {
      return isRoot()
        || adminHasInmobiliaria(inmoId)
        || (
          hasParentInmueble(inmoId, inmuebleId)
          && isOwner(parentInmueble(inmoId, inmuebleId))
        );
    }

    function isValidNetworkDataDocument(privateDocId, inmoId, inmuebleId) {
      return privateDocId == "networkData"
        && request.resource.data.keys().hasOnly([
          "exactAddress",
          "commissionShare",
          "internalPrice",
          "documentationStatus",
          "visitInstructions",
          "notesForColleagues",
          "ownerName",
          "ownerPhone",
          "inmobiliariaId",
          "inmuebleId",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.inmobiliariaId == inmoId
        && request.resource.data.inmuebleId == inmuebleId;
    }

    /* ============================
       USERS
       ============================ */

    match /users/{userId} {

      function existingUserInmobiliarias() {
        return resource.data.keys().hasAny(["inmobiliarias"])
          && resource.data.inmobiliarias is list
          ? resource.data.inmobiliarias
          : [];
      }

      function requestedUserInmobiliarias() {
        return request.resource.data.keys().hasAny(["inmobiliarias"])
          && request.resource.data.inmobiliarias is list
          ? request.resource.data.inmobiliarias
          : [];
      }

      function existingUserInmobiliariaRoles() {
        return resource.data.keys().hasAny(["inmobiliariaRoles"])
          && resource.data.inmobiliariaRoles is map
          ? resource.data.inmobiliariaRoles
          : {};
      }

      function requestedUserInmobiliariaRoles() {
        return request.resource.data.keys().hasAny(["inmobiliariaRoles"])
          && request.resource.data.inmobiliariaRoles is map
          ? request.resource.data.inmobiliariaRoles
          : {};
      }

function adminCanOnlyChangeOwnInmobiliariaLinks() {
  return isAdmin()
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "inmobiliarias",
        "inmobiliariaRoles",
        "updatedAt"
      ])
    && requestedUserInmobiliarias()
      .hasOnly(existingUserInmobiliarias().concat(userInmobiliarias()))
    && existingUserInmobiliarias()
      .hasOnly(requestedUserInmobiliarias().concat(userInmobiliarias()))
    && requestedUserInmobiliariaRoles()
      .diff(existingUserInmobiliariaRoles())
      .affectedKeys()
      .hasOnly(userInmobiliarias());
}

      function selfCanChangeActiveInmobiliaria() {
  return isSignedIn()
    && request.auth.uid == userId
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "activeInmobiliariaId",
        "updatedAt"
      ])
    && request.resource.data.activeInmobiliariaId in existingUserInmobiliarias();
}

      function existingUserRoles() {
  return resource.data.keys().hasAny(["roles"])
    && resource.data.roles is list
    ? resource.data.roles
    : [];
}

function requestedUserRoles() {
  return request.resource.data.keys().hasAny(["roles"])
    && request.resource.data.roles is list
    ? request.resource.data.roles
    : [];
}

function selfCanCompleteInmobiliariaRegistration() {
  return isSignedIn()
    && request.auth.uid == userId
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "uid",
        "email",
        "displayName",
        "role",
        "roles",
        "inmobiliarias",
        "activeInmobiliariaId",
        "inmobiliariaRoles",
        "updatedAt",
        "createdAt"
      ])
    && request.resource.data.activeInmobiliariaId is string
    && isSelfCreatedInmobiliaria(request.resource.data.activeInmobiliariaId)
    && requestedUserInmobiliarias()
      .hasOnly(
        existingUserInmobiliarias().concat([
          request.resource.data.activeInmobiliariaId
        ])
      )
    && existingUserInmobiliarias()
      .hasOnly(requestedUserInmobiliarias())
    && requestedUserRoles()
      .hasOnly(existingUserRoles().concat(["admin"]))
    && requestedUserRoles()
      .hasAll(existingUserRoles().concat(["admin"]))
    && (
      resource.data.keys().hasAny(["role"])
      && resource.data.role == "root"
        ? request.resource.data.role == "root"
        : request.resource.data.role == "admin"
    )
    && (
      !request.resource.data.keys().hasAny(["inmobiliariaRoles"])
      || requestedUserInmobiliariaRoles()
        .diff(existingUserInmobiliariaRoles())
        .affectedKeys()
        .size() == 0
      || (
        requestedUserInmobiliariaRoles()
          .diff(existingUserInmobiliariaRoles())
          .affectedKeys()
          .hasOnly([request.resource.data.activeInmobiliariaId])
        && request.resource.data.inmobiliariaRoles[
          request.resource.data.activeInmobiliariaId
        ] == "admin"
      )
    );
}

function adminCanApproveUserInmobiliariaLink() {
  return isSignedIn()
    && isAdmin()
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "role",
        "roles",
        "inmobiliarias",
        "activeInmobiliariaId",
        "inmobiliariaRoles",
        "updatedAt"
      ])
    && requestedUserInmobiliarias()
      .hasOnly(existingUserInmobiliarias().concat(userInmobiliarias()))
    && existingUserInmobiliarias()
      .hasOnly(requestedUserInmobiliarias())
    && requestedUserRoles()
      .hasOnly(existingUserRoles().concat(["admin"]))
    && requestedUserRoles()
      .hasAll(existingUserRoles())
    && (
      resource.data.keys().hasAny(["role"])
      && resource.data.role == "root"
        ? request.resource.data.role == "root"
        : request.resource.data.role == "admin"
    )
    && requestedUserInmobiliariaRoles()
      .diff(existingUserInmobiliariaRoles())
      .affectedKeys()
      .hasOnly(userInmobiliarias());
}

      allow get: if
        isSignedIn()
        && (
          request.auth.uid == userId
          || isRoot()
          || isAdmin()
        );

      allow list: if
        isSignedIn()
        && (
          isRoot()
          || isAdmin()
        );

      allow create: if
        isSignedIn()
        && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/users/$(userId));

allow update: if
  isRoot()
  || adminCanOnlyChangeOwnInmobiliariaLinks()
  || selfCanCompleteInmobiliariaRegistration()
  || adminCanApproveUserInmobiliariaLink()
  || selfCanChangeActiveInmobiliaria();

      allow delete: if isRoot();
    }

    /* ============================
       INMOBILIARIAS
       ============================ */

    match /inmobiliarias/{inmoId} {

      function validSelfServiceModules() {
  return request.resource.data.modulosSuscriptos is list
    && request.resource.data.modulosSuscriptos.hasOnly([
      "inmuebles",
      "consultas",
      "dominios",
      "branding",
      "usuarios"
    ])
    && request.resource.data.modulosSuscriptos.hasAll([
      "inmuebles",
      "consultas",
      "dominios",
      "branding",
      "usuarios"
    ]);
}

function validPendingVerificationData() {
  return request.resource.data.verificacion is map
    && request.resource.data.verificacion.estado == "pendiente_documentacion"
    && request.resource.data.verificacion.requiereDocumentacion == true
    && request.resource.data.verificacion.documentacionCompleta == false;
}

function canCreateSelfRegisteredInmobiliaria() {
  return isSignedIn()
    && request.resource.data.keys().hasOnly([
      "nombre",
      "razonSocial",
      "cuit",
      "slug",
      "activa",
      "dominiosPublicos",
      "modulosSuscriptos",
      "verificacion",
      "documentacionVerificacion",
      "noIndex",
      "seo",
      "configuracion",
      "branding",
      "admins",
      "createdBy",
      "createdByEmail",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.nombre is string
    && request.resource.data.nombre.size() >= 2
    && request.resource.data.slug is string
    && request.resource.data.slug.size() >= 2
    && request.resource.data.cuit is string
    && request.resource.data.cuit.size() >= 7
    && request.resource.data.activa == true
    && request.resource.data.admins is list
    && request.resource.data.admins.hasOnly([request.auth.uid])
    && request.auth.uid in request.resource.data.admins
    && request.resource.data.createdBy == request.auth.uid
    && request.resource.data.createdByEmail is string
    && request.resource.data.dominiosPublicos is list
    && request.resource.data.configuracion is map
    && request.resource.data.branding is map
    && request.resource.data.documentacionVerificacion is map
    && validSelfServiceModules()
    && validPendingVerificationData();
}

function adminCanUpdateOwnInmobiliaria(inmoId) {
  return isSignedIn()
    && adminHasInmobiliaria(inmoId)
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "nombre",
        "razonSocial",
        "cuit",
        "slug",
        "activa",
        "dominiosPublicos",
        "configuracion",
        "branding",
        "noIndex",
        "seo",
        "updatedAt",
        "updatedBy"
      ])
    && request.resource.data.updatedBy == request.auth.uid;
}

function adminCanUpdateVerificationDocumentation(inmoId) {
  return isSignedIn()
    && adminHasInmobiliaria(inmoId)
    && resource.data.verificacion.estado in [
      "pendiente_documentacion",
      "pendiente_revision",
      "observada"
    ]
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "verificacion",
        "documentacionVerificacion",
        "updatedAt",
        "updatedBy"
      ])
    && request.resource.data.updatedBy == request.auth.uid
    && request.resource.data.verificacion is map
    && request.resource.data.verificacion.estado in [
      "pendiente_documentacion",
      "pendiente_revision"
    ]
    && request.resource.data.verificacion.requiereDocumentacion == true
    && request.resource.data.verificacion.documentacionCompleta is bool
    && request.resource.data.documentacionVerificacion is map;
}

function adminCanAddInmobiliariaAdmin(inmoId) {
  return isSignedIn()
    && adminHasInmobiliaria(inmoId)
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "admins",
        "updatedAt",
        "updatedBy"
      ])
    && request.resource.data.updatedBy == request.auth.uid
    && request.resource.data.admins is list
    && resource.data.admins is list
    && resource.data.admins.hasOnly(request.resource.data.admins);
}

      allow read: if
        isRoot()
        || adminHasInmobiliaria(inmoId)
        || isPublicInmobiliaria(resource);

allow create: if
  isRoot()
  || canCreateSelfRegisteredInmobiliaria();

allow update: if
  isRoot()
  || adminCanUpdateOwnInmobiliaria(inmoId)
  || adminCanUpdateVerificationDocumentation(inmoId)
  || adminCanAddInmobiliariaAdmin(inmoId);

allow delete: if isRoot();

      /* ============================
         SUBCOLECCIÓN INMUEBLES
         ============================ */

      match /inmuebles/{inmuebleId} {

        /* =========
           READ
           ========= */
        allow read: if
          isRoot()
          || adminHasInmobiliaria(inmoId)
          || isOwner(resource)
          || canSharedRead(resource, inmoId)
          || canReadNetworkInmueble(resource)
          || isPublicInmueble(resource);

        /* =========
           CREATE
           ========= */
        allow create: if
          isSignedIn()
          && inmueblePublicDataHasNoProtectedFields(request.resource.data)
          && (
            isRoot()
            || (
              isAdmin()
              && belongsToUserInmobiliaria(inmoId)
              && request.resource.data.ownerId == request.auth.uid
              && request.resource.data.ownerInmobiliariaId == inmoId
            )
          );

        /* =========
           UPDATE
           ========= */
        allow update: if
          isSignedIn()
          && inmueblePublicDataHasNoProtectedFields(request.resource.data)
          && (
            isRoot()
            || adminHasInmobiliaria(inmoId)
            || isOwner(resource)
            || (
              canSharedUpdate(resource, inmoId)
              && sharedCanUpdateOnlyAllowedFields(resource)
            )
          );

        /* =========
           DELETE
           ========= */
        allow delete: if
          isRoot()
          || adminHasInmobiliaria(inmoId);

        /* ============================
           DATOS PRIVADOS DEL INMUEBLE

           /inmobiliarias/{inmoId}/inmuebles/{inmuebleId}/private/networkData
           ============================ */

        match /private/{privateDocId} {

          allow get: if
            privateDocId == "networkData"
            && canReadInmueblePrivateData(inmoId, inmuebleId);

          allow list: if false;

          allow create, update: if
            isSignedIn()
            && canManageInmueblePrivateData(inmoId, inmuebleId)
            && isValidNetworkDataDocument(privateDocId, inmoId, inmuebleId);

          allow delete: if
            privateDocId == "networkData"
            && canManageInmueblePrivateData(inmoId, inmuebleId);
        }
      }
    }

    /* ============================
       COLLECTION GROUP: INMUEBLES
       ============================

       Permite:
       - Leer inmuebles públicos del portal.
       - Leer inmuebles compartidos en Red de colegas para usuarios de inmobiliarias.
    */

    match /{path=**}/inmuebles/{inmuebleId} {
      allow read: if
        isPublicInmueble(resource)
        || canReadNetworkInmueble(resource);

      allow create, update, delete: if false;
    }

    /* ============================
       CONSULTAS DE INMUEBLES
       ============================ */

    match /inmueble_consultas/{consultaId} {

      allow create: if
        request.resource.data.inmuebleId is string
        && request.resource.data.inmobiliariaId is string
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && (
          (
            request.resource.data.email is string
            && request.resource.data.email.size() >= 5
          )
          ||
          (
            request.resource.data.telefono is string
            && request.resource.data.telefono.size() >= 6
          )
        )
        && request.resource.data.estado == "nueva"
        && request.resource.data.leida == false
        && request.resource.data.archivada == false;

      allow read: if
        isRoot()
        || adminHasInmobiliaria(resource.data.inmobiliariaId);

      allow update: if
        isSignedIn()
        && (
          isRoot()
          || adminHasInmobiliaria(resource.data.inmobiliariaId)
        )
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            "estado",
            "leida",
            "archivada",
            "notaInterna",
            "lastContactAt",
            "lastContactBy",
            "updatedAt"
          ])
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(["notaInterna"])
            || request.resource.data.notaInterna is string
          )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(["lastContactBy"])
            || request.resource.data.lastContactBy == request.auth.uid
          );

      allow delete: if isRoot();
    }

    /* ============================
   SOLICITUDES RED DE COLEGAS
   ============================ */

match /inmueble_network_requests/{requestId} {

  allow create: if
    isSignedIn()
    && request.resource.data.keys().hasOnly([
      "inmuebleId",
      "inmuebleTitulo",
      "ownerInmobiliariaId",
      "requesterInmobiliariaId",
      "requesterUserId",
      "requesterUserEmail",
      "mensaje",
      "estado",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.inmuebleId is string
    && request.resource.data.ownerInmobiliariaId is string
    && request.resource.data.requesterInmobiliariaId is string
    && request.resource.data.requesterUserId == request.auth.uid
    && request.resource.data.ownerInmobiliariaId != request.resource.data.requesterInmobiliariaId
    && request.resource.data.estado == "pendiente"
    && belongsToUserInmobiliaria(request.resource.data.requesterInmobiliariaId);

  allow read: if
    isRoot()
    || adminHasInmobiliaria(resource.data.ownerInmobiliariaId)
    || adminHasInmobiliaria(resource.data.requesterInmobiliariaId)
    || resource.data.requesterUserId == request.auth.uid;

  allow update: if
    isSignedIn()
    && (
      isRoot()
      || adminHasInmobiliaria(resource.data.ownerInmobiliariaId)
    )
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "estado",
        "updatedAt"
      ])
    && request.resource.data.estado in [
      "pendiente",
      "aceptada",
      "rechazada",
      "cerrada"
    ];

  allow delete: if isRoot();
}

/* ============================
   SOLICITUDES DE VINCULACIÓN A INMOBILIARIA
   ============================ */

match /inmobiliaria_user_link_requests/{requestId} {

  allow create: if
    isSignedIn()
    && request.resource.data.keys().hasOnly([
      "inmobiliariaId",
      "inmobiliariaNombre",
      "requesterUserId",
      "requesterUserEmail",
      "requesterDisplayName",
      "requestedRole",
      "mensaje",
      "estado",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.inmobiliariaId is string
    && request.resource.data.inmobiliariaId.size() > 0
    && request.resource.data.inmobiliariaNombre is string
    && request.resource.data.requesterUserId == request.auth.uid
    && request.resource.data.requesterUserEmail is string
    && request.resource.data.requestedRole in [
      "admin",
      "editor",
      "viewer"
    ]
    && request.resource.data.estado == "pendiente"
    && exists(/databases/$(database)/documents/inmobiliarias/$(request.resource.data.inmobiliariaId));

  allow read: if
    isRoot()
    || resource.data.requesterUserId == request.auth.uid
    || adminHasInmobiliaria(resource.data.inmobiliariaId);

  allow update: if
    isRoot()
    || (
      adminHasInmobiliaria(resource.data.inmobiliariaId)
      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "estado",
          "updatedAt",
          "reviewedAt",
          "reviewedBy",
          "reviewNote"
        ])
      && request.resource.data.estado in [
        "pendiente",
        "aceptada",
        "rechazada",
        "cancelada"
      ]
      && request.resource.data.reviewedBy == request.auth.uid
    );

  allow delete: if isRoot();
}

    /* ============================
       TESTIMONIALS
       ============================ */

    match /testimonials/{testimonialId} {

      allow read: if true;

      allow create: if isSignedIn();

      allow update, delete: if isAdmin() || isRoot();
    }

/* ============================
   SOLICITUDES DE PUBLICACIÓN PARTICULAR
   ============================ */

match /particular_publication_requests/{requestId} {

  function validPublicationTarget() {
    return (
      request.resource.data.targetType == "onoprop"
      && request.resource.data.targetInmobiliariaId == ""
      && request.resource.data.targetInmobiliariaNombre == "ONO Prop"
      && request.resource.data.assignedInmobiliariaId == ""
      && request.resource.data.assignedInmobiliariaNombre == ""
      && request.resource.data.assignedBy == ""
      && request.resource.data.validationOwner == "onoprop"
      && request.resource.data.publicationMode == "particular"
    )
    ||
    (
      request.resource.data.targetType == "inmobiliaria"
      && request.resource.data.targetInmobiliariaId is string
      && request.resource.data.targetInmobiliariaId.size() > 0
      && request.resource.data.targetInmobiliariaNombre is string
      && request.resource.data.targetInmobiliariaNombre.size() >= 2
      && request.resource.data.assignedInmobiliariaId == request.resource.data.targetInmobiliariaId
      && request.resource.data.assignedInmobiliariaNombre == request.resource.data.targetInmobiliariaNombre
      && request.resource.data.assignedBy == request.auth.uid
      && request.resource.data.validationOwner == "inmobiliaria"
      && request.resource.data.publicationMode == "inmobiliaria"
      && exists(/databases/$(database)/documents/inmobiliarias/$(request.resource.data.targetInmobiliariaId))
    );
  }

  function particularRequestUpdateAllowedFields() {
    return [
      "estado",
      "internalNote",
      "reviewedAt",
      "reviewedBy",
      "updatedAt",

      "activityLog",

      "convertedInmuebleId",
      "convertedInmobiliariaId",
      "convertedTitle",
      "convertedSlug",
      "convertedEditPath",
      "convertedPreviewPath",
      "convertedPublicPath",
      "convertedPublicVisible",
      "convertedPublicStatus",
      "convertedPublishedAt",
      "convertedVisibilityUpdatedAt",
      "convertedVisibilityUpdatedBy",

      "conversionLockStatus",
      "conversionStartedAt",
      "conversionStartedBy",
      "conversionCompletedAt",
      "conversionError",
      "conversionFailedAt",
      "conversionFailedBy",

      "approvalMode",
      "particularPublicationId",
      "particularPublicationPath",
      "particularPublicationStatus",
      "particularPublicationApprovedAt",
      "particularPublicationApprovedBy",

      "convertedAt",
      "convertedBy"
    ];
  }

  function particularRequestChangedKeys() {
    return request.resource.data
      .diff(resource.data)
      .affectedKeys();
  }

  function validParticularRequestStatusUpdate() {
    return request.resource.data.estado in [
      "nuevo",
      "en_revision",
      "contactado",
      "derivado",
      "cerrado",
      "descartado"
    ];
  }

  function validParticularRequestUpdateActor() {
    return (
      !particularRequestChangedKeys().hasAny([
        "estado",
        "internalNote",
        "reviewedAt",
        "reviewedBy"
      ])
      || request.resource.data.reviewedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny([
        "conversionLockStatus",
        "conversionStartedAt",
        "conversionStartedBy"
      ])
      || request.resource.data.conversionStartedBy == request.auth.uid
      || request.resource.data.convertedBy == request.auth.uid
      || request.resource.data.conversionFailedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny([
        "conversionError",
        "conversionFailedAt",
        "conversionFailedBy"
      ])
      || request.resource.data.conversionFailedBy == request.auth.uid
      || request.resource.data.conversionStartedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny([
        "convertedInmuebleId",
        "convertedInmobiliariaId",
        "convertedTitle",
        "convertedSlug",
        "convertedEditPath",
        "convertedPreviewPath",
        "convertedPublicPath",
        "conversionCompletedAt",
        "convertedAt",
        "convertedBy"
      ])
      || request.resource.data.convertedBy == request.auth.uid
      || request.resource.data.convertedVisibilityUpdatedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny([
        "convertedPublicVisible",
        "convertedPublicStatus",
        "convertedPublishedAt",
        "convertedVisibilityUpdatedAt",
        "convertedVisibilityUpdatedBy"
      ])
      || request.resource.data.convertedVisibilityUpdatedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny([
        "approvalMode",
        "particularPublicationId",
        "particularPublicationPath",
        "particularPublicationStatus",
        "particularPublicationApprovedAt",
        "particularPublicationApprovedBy"
      ])
      || request.resource.data.particularPublicationApprovedBy == request.auth.uid
      || request.resource.data.reviewedBy == request.auth.uid
    );
  }

  function validParticularRequestUpdateTypes() {
    return (
      !particularRequestChangedKeys().hasAny(["internalNote"])
      || request.resource.data.internalNote is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["conversionError"])
      || request.resource.data.conversionError is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedInmuebleId"])
      || request.resource.data.convertedInmuebleId is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedInmobiliariaId"])
      || request.resource.data.convertedInmobiliariaId is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedTitle"])
      || request.resource.data.convertedTitle is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedSlug"])
      || request.resource.data.convertedSlug is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedEditPath"])
      || request.resource.data.convertedEditPath is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedPreviewPath"])
      || request.resource.data.convertedPreviewPath is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedPublicPath"])
      || request.resource.data.convertedPublicPath is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedPublicVisible"])
      || request.resource.data.convertedPublicVisible is bool
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedPublicStatus"])
      || request.resource.data.convertedPublicStatus in [
        "published",
        "draft"
      ]
    )
    && (
      !particularRequestChangedKeys().hasAny(["conversionLockStatus"])
      || request.resource.data.conversionLockStatus in [
        "processing",
        "converted",
        "failed"
      ]
    )
    && (
      !particularRequestChangedKeys().hasAny(["convertedPublishedAt"])
      || request.resource.data.convertedPublishedAt is timestamp
      || request.resource.data.convertedPublishedAt == null
    )
    && (
      !particularRequestChangedKeys().hasAny(["approvalMode"])
      || request.resource.data.approvalMode in [
        "particular_publication",
        "inmobiliaria_conversion"
      ]
    )
    && (
      !particularRequestChangedKeys().hasAny(["particularPublicationId"])
      || request.resource.data.particularPublicationId is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["particularPublicationPath"])
      || request.resource.data.particularPublicationPath is string
    )
    && (
      !particularRequestChangedKeys().hasAny(["particularPublicationStatus"])
      || request.resource.data.particularPublicationStatus in [
        "active",
        "paused",
        "deleted",
        "sold",
        "rented"
      ]
    )
    && (
      !particularRequestChangedKeys().hasAny(["particularPublicationApprovedAt"])
      || request.resource.data.particularPublicationApprovedAt is timestamp
    )
    && (
      !particularRequestChangedKeys().hasAny(["particularPublicationApprovedBy"])
      || request.resource.data.particularPublicationApprovedBy == request.auth.uid
    )
    && (
      !particularRequestChangedKeys().hasAny(["activityLog"])
      || (
        request.resource.data.activityLog is list
        && request.resource.data.activityLog.size() <= 100
      )
    );
  }

  function validParticularPublicationApprovalScope() {
    return !particularRequestChangedKeys().hasAny([
        "approvalMode",
        "particularPublicationId",
        "particularPublicationPath",
        "particularPublicationStatus",
        "particularPublicationApprovedAt",
        "particularPublicationApprovedBy"
      ])
      || isRoot();
  }

  function validConvertedInmobiliariaScope() {
    return !particularRequestChangedKeys().hasAny(["convertedInmobiliariaId"])
      || isRoot()
      || request.resource.data.convertedInmobiliariaId == resource.data.targetInmobiliariaId;
  }

  function canManageParticularRequestUpdate() {
    return isRoot()
      || (
        resource.data.targetType == "inmobiliaria"
        && adminHasInmobiliaria(resource.data.targetInmobiliariaId)
      );
  }

  allow create: if
    isSignedIn()
    && request.resource.data.keys().hasOnly([
      "requesterUserId",
      "requesterEmail",
      "requesterDisplayName",

      "activityLog",

      "nombre",
      "telefono",
      "email",
      "operacion",
      "tipo",
      "ubicacion",
      "descripcion",
      "precioEstimado",
      "images",
      "videos",

      "targetType",
      "targetInmobiliariaId",
      "targetInmobiliariaNombre",
      "assignedInmobiliariaId",
      "assignedInmobiliariaNombre",
      "assignedAt",
      "assignedBy",
      "validationOwner",
      "publicationMode",

      "billingStatus",
      "billingModel",

      "estado",
      "origen",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.requesterUserId == request.auth.uid
    && request.resource.data.requesterEmail is string
    && request.resource.data.requesterDisplayName is string

    && request.resource.data.nombre is string
    && request.resource.data.nombre.size() >= 2

    && request.resource.data.telefono is string
    && request.resource.data.email is string
    && (
      request.resource.data.telefono.size() >= 6
      || request.resource.data.email.size() >= 6
    )

    && request.resource.data.operacion in [
      "venta",
      "alquiler",
      "alquiler_temporal",
      "tasacion"
    ]

    && request.resource.data.tipo in [
      "casa",
      "departamento",
      "terreno",
      "local",
      "oficina",
      "cochera",
      "campo",
      "otro"
    ]

    && request.resource.data.ubicacion is string
    && request.resource.data.ubicacion.size() >= 3

    && request.resource.data.descripcion is string
    && request.resource.data.descripcion.size() >= 20

    && request.resource.data.precioEstimado is string

    && request.resource.data.images is list
    && request.resource.data.images.size() <= 50

    && (
      !request.resource.data.keys().hasAny(["videos"])
      || (
        request.resource.data.videos is list
        && request.resource.data.videos.size() <= 5
      )
    )

    && request.resource.data.activityLog is list
    && request.resource.data.activityLog.size() <= 20

    && request.resource.data.billingStatus == "free"
    && request.resource.data.billingModel == "none"

    && request.resource.data.estado == "nuevo"
    && request.resource.data.origen == "portal_publicar"
    && validPublicationTarget();

  allow read: if
    isRoot()
    || (
      isSignedIn()
      && resource.data.requesterUserId == request.auth.uid
    )
    || (
      resource.data.targetType == "inmobiliaria"
      && adminHasInmobiliaria(resource.data.targetInmobiliariaId)
    );

  allow update: if
    isSignedIn()
    && canManageParticularRequestUpdate()
    && particularRequestChangedKeys()
      .hasOnly(particularRequestUpdateAllowedFields())
    && validParticularRequestStatusUpdate()
    && validParticularRequestUpdateActor()
    && validParticularRequestUpdateTypes()
    && validParticularPublicationApprovalScope()
    && validConvertedInmobiliariaScope();

  allow delete: if isRoot();
}

    /* ============================
       PUBLICACIONES PARTICULARES APROBADAS
       ============================ */

    match /particular_publications/{publicationId} {

      function isPublicApprovedParticularPublication() {
        return resource.data.publicationType == "particular"
          && resource.data.publicStatus == "active"
          && resource.data.moderationStatus == "approved";
      }

      function isParticularPublicationOwner() {
        return isSignedIn()
          && resource.data.ownerUserId == request.auth.uid;
      }

      function validParticularPublicationCreate() {
        return isRoot()
          && request.resource.data.keys().hasOnly([
            "ownerUserId",
            "ownerEmail",
            "ownerDisplayName",
            "sourceRequestId",
            "publicationType",
            "titulo",
            "operacion",
            "tipo",
            "ubicacion",
            "descripcion",
            "precioEstimado",
            "images",
            "videos",
            "contact",
            "publicStatus",
            "moderationStatus",
            "moderationNote",
            "pendingChanges",
            "sourceTargetType",
            "sourceValidationOwner",
            "noIndex",
            "activityLog",
            "createdAt",
            "updatedAt",
            "approvedAt",
            "approvedBy",
            "statusUpdatedAt",
            "statusUpdatedBy"
          ])
          && request.resource.data.ownerUserId is string
          && request.resource.data.ownerUserId.size() > 0
          && request.resource.data.sourceRequestId is string
          && request.resource.data.sourceRequestId.size() > 0
          && request.resource.data.publicationType == "particular"
          && request.resource.data.titulo is string
          && request.resource.data.titulo.size() >= 5
          && request.resource.data.operacion is string
          && request.resource.data.tipo is string
          && request.resource.data.ubicacion is string
          && request.resource.data.descripcion is string
          && request.resource.data.descripcion.size() >= 20
          && request.resource.data.images is list
          && request.resource.data.images.size() <= 50

          && (
            !request.resource.data.keys().hasAny(["videos"])
            || (
              request.resource.data.videos is list
              && request.resource.data.videos.size() <= 5
            )
          )

          && request.resource.data.contact is map
          && request.resource.data.publicStatus == "active"
          && request.resource.data.moderationStatus == "approved"
          && request.resource.data.activityLog is list
          && request.resource.data.activityLog.size() <= 20
          && request.resource.data.approvedBy == request.auth.uid
          && request.resource.data.statusUpdatedBy == request.auth.uid;
      }

      function ownerCanUpdateParticularPublicationStatus() {
        return isParticularPublicationOwner()
          && resource.data.moderationStatus == "approved"
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              "publicStatus",
              "pausedAt",
              "pausedBy",
              "deletedAt",
              "deletedBy",
              "soldAt",
              "soldBy",
              "rentedAt",
              "rentedBy",
              "statusUpdatedAt",
              "statusUpdatedBy",
              "updatedAt",
              "activityLog"
            ])
          && request.resource.data.publicStatus in [
            "active",
            "paused",
            "deleted",
            "sold",
            "rented"
          ]
          && request.resource.data.statusUpdatedBy == request.auth.uid
          && request.resource.data.activityLog is list
          && request.resource.data.activityLog.size() <= 100;
      }

      allow read: if
        isPublicApprovedParticularPublication()
        || isRoot()
        || isParticularPublicationOwner();

      allow create: if validParticularPublicationCreate();

      allow update: if
        isRoot()
        || ownerCanUpdateParticularPublicationStatus();

      allow delete: if isRoot();
    }

        /* ============================
       CONFIGURACIÓN REGLAS ORDEN DE PUBLICACIONES
       ============================ */

    match /portal_config/{configId} {   
      allow read: if true;
      allow write: if isRoot();
    }

    /* ============================
       CIERRE TOTAL
       ============================ */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}